rules_version = '2';

// RBAC for the Student Data Management System.
// Students are records, not users. Only staff authenticate:
//   - SUPER_ADMIN: full control; provisions/manages teacher accounts.
//   - TEACHER:     full CRUD on student records and forms.
// Students (the public) can read published forms and submit responses.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function currentRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isSuperAdmin() {
      return isSignedIn() && currentRole() == 'SUPER_ADMIN';
    }

    function isStaff() {
      return isSignedIn() && currentRole() in ['TEACHER', 'SUPER_ADMIN'];
    }

    // Staff accounts — provisioned server-side via the Admin SDK.
    match /users/{uid} {
      allow read: if (isSignedIn() && request.auth.uid == uid) || isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    // Student records — full CRUD for any authenticated staff member.
    match /students/{studentId} {
      allow read, create, update, delete: if isStaff();
    }

    // Forms — staff manage; the public may READ only PUBLISHED forms
    // (so a shared link renders without a login).
    match /forms/{formId} {
      allow read: if isStaff() || resource.data.status == 'published';
      allow create, update, delete: if isStaff();
    }

    // Submissions — the public may CREATE a pending response to a published
    // form; only staff can read or act on them.
    match /submissions/{submissionId} {
      allow read, update, delete: if isStaff();
      allow create: if request.resource.data.status == 'pending'
        && exists(/databases/$(database)/documents/forms/$(request.resource.data.formId))
        && get(/databases/$(database)/documents/forms/$(request.resource.data.formId)).data.status == 'published';
    }
  }
}
