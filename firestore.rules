rules_version = '2';

// RBAC for the Student Data Management System.
// Students are records, not users. Only staff authenticate:
//   - SUPER_ADMIN: full control; provisions/manages teacher accounts.
//   - TEACHER:     full CRUD on student records.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Role of the CURRENT user, or null if they have no staff document.
    // Guarded with exists() so it never errors on a missing doc.
    function currentRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isSuperAdmin() {
      return isSignedIn() && currentRole() == 'SUPER_ADMIN';
    }

    function isStaff() {
      return isSignedIn() && currentRole() in ['TEACHER', 'SUPER_ADMIN'];
    }

    // Staff accounts. Provisioning happens server-side via the Admin SDK, so
    // creation/updates from clients are restricted to the SUPER_ADMIN.
    match /users/{uid} {
      allow read: if (isSignedIn() && request.auth.uid == uid) || isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    // Student records — any authenticated staff member has full CRUD.
    match /students/{studentId} {
      allow read, create, update, delete: if isStaff();
    }
  }
}
