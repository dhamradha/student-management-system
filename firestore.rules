rules_version = '2';

// RBAC for the Student Data Management System (SRS §3).
//  - SUPER_ADMIN: full read/write/delete, manages roles.
//  - ADMIN:       read all students, update (verify) student documents.
//  - STUDENT:     read/write ONLY their own document; no cross-document queries.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Role of the CURRENT user, or null if they have no document yet.
    // Guarded with exists() so it never errors on a missing doc — critical
    // during a student's first registration, before their profile is written.
    function currentRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isSuperAdmin() {
      return isSignedIn() && currentRole() == 'SUPER_ADMIN';
    }

    function isAdmin() {
      return isSignedIn() && currentRole() in ['ADMIN', 'SUPER_ADMIN'];
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Students may create their own doc, but may never elevate their own role
    // or self-approve. Only privileged fields are locked down here.
    function studentSafeWrite() {
      return request.resource.data.role == 'STUDENT'
        && request.resource.data.isApproved == false
        && request.resource.data.uid == request.auth.uid;
    }

    match /users/{uid} {
      // Read: self, or any admin.
      allow read: if isSelf(uid) || isAdmin();

      // Create: a student creating their own profile within safe bounds,
      // or a super admin provisioning any account.
      allow create: if isSuperAdmin()
        || (isSelf(uid) && studentSafeWrite());

      // Update:
      //  - Student editing own doc (cannot flip role/isApproved).
      //  - Admin verifying a student (approve/reject/update).
      //  - Super admin: unrestricted.
      allow update: if isSuperAdmin()
        || (isAdmin() && resource.data.role == 'STUDENT')
        || (isSelf(uid) && studentSafeWrite());

      // Delete: super admin only.
      allow delete: if isSuperAdmin();
    }

    // Audit log — append-only for admins, readable by super admin (SRS §3).
    match /logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
