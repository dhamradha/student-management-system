# ---------------------------------------------------------------------------
# Firebase Web (client) SDK — safe to expose to the browser.
# Firebase Console > Project settings > General > Your apps > Web app config
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Domain used to synthesise a login email from a student's admission number.
# Students never see this — they log in with admission number + password.
NEXT_PUBLIC_STUDENT_EMAIL_DOMAIN=students.hunuwala.lk

# ---------------------------------------------------------------------------
# Firebase Admin (server) SDK — SECRET. Never expose with NEXT_PUBLIC_.
# Firebase Console > Project settings > Service accounts > Generate new key.
# Paste the values from the downloaded JSON. Keep \n literal in the private key.
# ---------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
